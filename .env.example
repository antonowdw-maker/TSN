# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Прокси для Bot API (если api.telegram.org недоступен напрямую)
# Примеры: http://127.0.0.1:7890  или  socks5://127.0.0.1:10808
TELEGRAM_PROXY=

# Таймауты подключения к Telegram API (секунды)
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30

# Ключ OpenAI API (опционально — для ответов на вопросы вне FAQ)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Минимальный порог совпадения FAQ (0-100)
FAQ_MATCH_THRESHOLD=65
